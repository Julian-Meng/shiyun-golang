{
  "name": "shiyun",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "诗云 / Poetry Cloud — a roamable 3D star map of all possible regulated-verse poems, indexed not stored.",
  "scripts": {
    "dev": "vite",
    "build": "tsc --noEmit && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "precompress": "node deploy/precompress.mjs",
    "build:sidecars": "node pipeline/build-sidecars.mjs",
    "build:lines": "node --max-old-space-size=4096 pipeline/build-lines.mjs",
    "deploy:build": "npm run build && npm run precompress"
  },
  "dependencies": {
    "@react-three/drei": "^9.114.3",
    "@react-three/fiber": "^8.17.10",
    "@react-three/postprocessing": "^2.19.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "three": "^0.169.0",
    "zustand": "^5.0.2"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@types/three": "^0.169.0",
    "@vitejs/plugin-react": "^4.3.4",
    "opencc-js": "^1.3.1",
    "pinyin-pro": "^3.28.1",
    "typescript": "^5.6.3",
    "vite": "^5.4.11",
    "vitest": "^2.1.8"
  }
}
